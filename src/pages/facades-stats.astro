---
// src/pages/facades-stats.astro
const acceptLang = Astro.request.headers.get('accept-language') || 'de';
const prefs = acceptLang.toLowerCase().split(',').map(l => l.trim().substring(0, 2));
const lang = prefs.find(l => ['de', 'en', 'it'].includes(l)) || 'de';

const trans = {
    de: {
        title: "Burg | Alle Fassaden", head: "Burg - Alle Fassaden (LTS)", loadData: "Lade Daten...",
        init: "INITIALISIERE...", loadingStats: "Rufe kombinierte Statistiken ab...", back: "Zurück",
        online: "VERBUNDEN", errorNet: "Netzwerkfehler.",
        last24Hours: "⏱️ Letzte 24 Stunden",
        last15Days: "📅 Letzte 15 Tage (Tageswerte in °C)", histData: "📈 Historische Daten (LTS)",
        monthlyData: "📅 Monatswerte", north: "Nord", south: "Süd", east: "Ost", west: "West",
        monthsShort: ['Jan', 'Feb', 'Mär', 'Apr', 'Mai', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez']
    },
    en: {
        title: "Burg | All Facades", head: "Burg - All Facades (LTS)", loadData: "Loading Data...",
        init: "INITIALIZING...", loadingStats: "Fetching combined statistics...", back: "Back",
        online: "CONNECTED", errorNet: "Network Error.",
        last24Hours: "⏱️ Last 24 Hours",
        last15Days: "📅 Last 15 Days (Daily values in °C)", histData: "📈 Historical Data (LTS)",
        monthlyData: "📅 Monthly Values", north: "North", south: "South", east: "East", west: "West",
        monthsShort: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
    },
    it: {
        title: "Burg | Tutte le Facciate", head: "Burg - Tutte le Facciate (LTS)", loadData: "Caricamento...",
        init: "INIZIALIZZAZIONE...", loadingStats: "Recupero statistiche combinate...", back: "Indietro",
        online: "CONNESSO", errorNet: "Errore di Rete.",
        last24Hours: "⏱️ Ultime 24 Ore",
        last15Days: "📅 Ultimi 15 Giorni (Valori giornalieri in °C)", histData: "📈 Dati Storici (LTS)",
        monthlyData: "📅 Valori Mensili", north: "Nord", south: "Sud", east: "Est", west: "Ovest",
        monthsShort: ['Gen', 'Feb', 'Mar', 'Apr', 'Mag', 'Giu', 'Lug', 'Ago', 'Set', 'Ott', 'Nov', 'Dic']
    }
};
const t = trans[lang];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{t.title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M18 20V10h2v10h-2M4 20V10h2v10H4m9-10v2h-2v-2h2m1-8l2 2v2h-2V2l-2 2-2-2v2H7V4L5 2v4h14V2l-2 2zM21 9h-2V7h-2v2h-2V7h-2v2h-2V7H9v2H7V7H5v2H3v12h18V9z'/></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><rect width='24' height='24' fill='black'/><path d='M18 20V10h2v10h-2M4 20V10h2v10H4m9-10v2h-2v-2h2m1-8l2 2v2h-2V2l-2 2-2-2v2H7V4L5 2v4h14V2l-2 2zM21 9h-2V7h-2v2h-2V7h-2v2h-2V7H9v2H7V7H5v2H3v12h18V9z'/></svg>">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#030303">
</head>
<body>
    
    <div class="floating-back clickable" onclick="if(window.opener){window.close();}else{window.location.href='/';}">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <span>{t.back}</span>
    </div>

    <div id="weather-bg" style="background-image: url('/garten_bg.webp');"></div>

    <div class="container">
        <header>
            <div class="brand">
                <h1>{t.head}</h1>
                <p style="color: var(--accent); font-weight: 700; font-size: 0.95rem;">{t.loadData}</p>
            </div>
            <div class="status-badge">
                <div id="status-indicator" class="status-dot"></div>
                <span id="status-text">{t.init}</span>
            </div>
        </header>

        <p id="loading" style="color: #9ca3af; font-family: 'JetBrains Mono', monospace;">{t.loadingStats}</p>
        <p id="error" style="display:none; color: #ef4444; font-family: 'JetBrains Mono', monospace;"></p>

        <div id="content" style="display:none;">
            <div class="card col-12" style="margin-bottom: 1.25rem; padding: 1rem 1.75rem;">
                <div style="display:flex; justify-content:space-between; font-family:'JetBrains Mono', monospace; font-size:0.75rem; font-weight:700; letter-spacing:0.05em; text-transform:uppercase;">
                    <span style="color: #000000; filter: drop-shadow(0 0 2px rgba(255,255,255,0.4));">● {t.north}</span>
                    <span style="color: #ef4444;">● {t.south}</span>
                    <span style="color: #14b8a6;">● {t.east}</span>
                    <span style="color: #ffffff;">● {t.west}</span>
                </div>
            </div>

            <div class="bento-grid" id="hourly-section" style="display:none;"></div>
            <div class="bento-grid" id="daily-section" style="display:none;"></div>
            
            <h2 class="section-title" id="monthly-title" style="display:none;">{t.histData}</h2>
            <div class="bento-grid" id="monthly-section" style="display:none;"></div>
        </div>
    </div>

    <script is:inline set:html={`const t = ${JSON.stringify(t)};`}></script>
    <script is:inline>
        const statusDot = document.getElementById('status-indicator');
        const statusText = document.getElementById('status-text');
        const weatherBg = document.getElementById('weather-bg');

        function applyWeatherTone(lux, isRaining) {
            if (!weatherBg) return;
            const brightness = 0.3 + (Math.log10(Math.max(1, lux)) / 4.5) * 0.7;
            const saturation = 0.4 + (Math.log10(Math.max(1, lux)) / 4.5) * 0.7;
            let filterString = `brightness(${Math.min(1.2, brightness).toFixed(2)}) saturate(${Math.min(1.3, saturation).toFixed(2)}) blur(${isRaining ? 8 : 5}px)`;
            if (isRaining) filterString += ` contrast(0.85) sepia(0.15) hue-rotate(185deg)`;
            weatherBg.style.filter = filterString;
        }

        fetch('/api/status').then(r => r.json()).then(data => {
            if (data.weather_station) applyWeatherTone(data.weather_station.lux || 0, data.weather_station.is_raining);
        });

        const apis = [
            'sensor.temperature_and_humidity_sensor_outdoor_north_temperature',
            'sensor.temperature_and_humidity_sensor_outdoor_balkon_temperature',
            'sensor.temperature_and_humidity_sensor_outdoor_house_east_temperature',
            'sensor.temperature_and_humidity_sensor_outdoor_west_temperature'
        ];
        
        // Exact matched order: North(Black), South(Red), East(Blue-Green), West(White)
        const colors = ['#000000', '#ef4444', '#14b8a6', '#ffffff'];

        Promise.all(apis.map(api => fetch(`/api/temperature?entity_id=${api}`).then(r => r.json())))
        .then(results => {
            document.getElementById('loading').style.display = 'none';
            if (results.some(r => r.error)) {
                document.getElementById('error').innerText = t.errorNet;
                document.getElementById('error').style.display = 'block';
                return;
            }

            document.getElementById('content').style.display = 'block';
            statusDot.className = "status-dot online";
            statusText.innerText = t.online;

            function generateMultiLineHTML(titleText, seriesArrays, labelsHTML, svgWidth, svgHeight) {
                let allVals = [];
                seriesArrays.forEach(arr => {
                    if(arr) arr.forEach(val => { if(val !== null && val !== undefined) allVals.push(val); });
                });
                if(allVals.length === 0) return '';
                
                const realMax = Math.max(...allVals);
                const realMin = Math.min(...allVals);
                let minVal = realMin;
                let maxVal = realMax;
                const padding = (maxVal - minVal) * 0.1 || 1;
                maxVal += padding; 
                minVal -= padding;
                const range = maxVal - minVal || 1;

                const getY = (temp) => svgHeight - (((temp - minVal) / range) * svgHeight);

                let pathsHTML = '';
                seriesArrays.forEach((arr, idx) => {
                    if (!arr || arr.length === 0) return;
                    let pathD = "";
                    let first = true;
                    arr.forEach((val, i) => {
                        if (val === null || val === undefined) return;
                        const x = (i / (arr.length - 1)) * svgWidth;
                        const y = getY(val);
                        if (first) { pathD += `M ${x} ${y} `; first = false; }
                        else pathD += `L ${x} ${y} `;
                    });
                    const filter = colors[idx] === '#000000' ? `filter: drop-shadow(0px 0px 2px rgba(255,255,255,0.4));` : '';
                    pathsHTML += `<path d="${pathD}" fill="none" stroke="${colors[idx]}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="${filter}" />`;
                });

                return `
                    <div class="card col-12">
                        <div class="card-title">${titleText} <span style="float:right; font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); text-transform:none;">Min: ${realMin.toFixed(1)}° | Max: ${realMax.toFixed(1)}°</span></div>
                        <div class="history-chart-grid">
                            <div style="width: 100%; min-width: 1200px; display: flex; flex-direction: column;">
                                <svg viewBox="0 0 ${svgWidth} ${svgHeight}" preserveAspectRatio="none" style="width: 100%; height: 140px; overflow: visible;">
                                    ${pathsHTML}
                                </svg>
                                <div style="display: flex; justify-content: space-between; margin-top: 5px; width: 100%;">
                                    ${labelsHTML}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }

            function generateMultiBarHTML(titleText, seriesArrays, labelsArray) {
                let allVals = [];
                seriesArrays.forEach(arr => {
                    if(arr) arr.forEach(val => { if(val !== null && val !== undefined) allVals.push(val); });
                });
                if(allVals.length === 0) return '';
                
                const realMax = Math.max(...allVals);
                const realMin = Math.min(...allVals);
                let minVal = Math.min(realMin, 0);
                let maxVal = Math.max(realMax, 1);
                if(minVal > 0) minVal = 0;
                const range = maxVal - minVal || 1;

                let colsHTML = '';
                
                labelsArray.forEach((label, i) => {
                    let barsHTML = '';
                    seriesArrays.forEach((arr, idx) => {
                        const val = arr[i];
                        if (val !== null && val !== undefined) {
                            const pct = val === 0 ? 0 : Math.max(1, ((val - minVal) / range) * 100);
                            barsHTML += `<div class="chart-bar" style="position: absolute; bottom: 0; left: 0; width: 100%; height: ${pct}%; background: ${colors[idx]}; opacity: 0.55; border-radius: 2px 2px 0 0;"></div>`;
                        }
                    });

                    colsHTML += `
                        <div class="chart-column">
                            <div class="chart-bar-container" style="position: relative;">
                                ${barsHTML}
                            </div>
                            <div class="chart-label">${label}</div>
                        </div>
                    `;
                });

                return `
                    <div class="card col-12" style="margin-bottom: 20px;">
                        <div class="card-title">${titleText} <span style="float:right; font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); text-transform:none;">Min: ${realMin.toFixed(1)}° | Max: ${realMax.toFixed(1)}°</span></div>
                        <div class="history-chart-grid">
                            ${colsHTML}
                        </div>
                    </div>
                `;
            }

            // 1. Hourly Stats
            const hourlySeries = results.map(r => r.hourly ? r.hourly.map(h => h.mean) : []);
            let hLabelsHTML = '';
            const numLabels = 24;
            const refPoints = results[0].hourly || [];
            
            for (let i = 0; i < numLabels; i++) {
                const pointIdx = Math.floor((i / (numLabels - 1)) * (refPoints.length - 1));
                const hr = refPoints[pointIdx] ? new Date(refPoints[pointIdx].start).getHours() : '';
                hLabelsHTML += `<div style="display:flex; flex-direction:column; align-items:center; flex:1;"><div class="chart-label" style="margin-top:0.5rem;">${hr}</div></div>`;
            }
            
            const hSection = document.getElementById('hourly-section');
            hSection.innerHTML = generateMultiLineHTML(`${t.last24Hours} (in °C)`, hourlySeries, hLabelsHTML, 800, 140);
            hSection.style.display = 'block';

            // 2. Daily Stats
            const dailySeries = results.map(r => r.daily ? r.daily.map(d => d.mean) : []);
            const dRef = results[0].daily || [];
            const dLabels = dRef.map(point => {
                const dateObj = new Date(point.start);
                return `${dateObj.getDate().toString().padStart(2,'0')}.${(dateObj.getMonth()+1).toString().padStart(2,'0')}`;
            });
            
            const dSection = document.getElementById('daily-section');
            dSection.innerHTML = generateMultiBarHTML(t.last15Days, dailySeries, dLabels);
            dSection.style.display = 'block';

            // 3. Monthly Stats
            const yearsSet = new Set();
            results.forEach(r => {
                if(r.monthly) r.monthly.forEach(m => yearsSet.add(new Date(m.start).getFullYear()));
            });
            const sortedYears = Array.from(yearsSet).sort((a,b) => b-a);
            
            const monthlySection = document.getElementById('monthly-section');
            const mLabels = t.monthsShort;

            sortedYears.forEach(year => {
                const mSeriesArrays = results.map(r => {
                    const arr = new Array(12).fill(null);
                    if(r.monthly) {
                        r.monthly.forEach(point => {
                            const d = new Date(point.start);
                            if(d.getFullYear() === year) arr[d.getMonth()] = point.mean;
                        });
                    }
                    return arr;
                });
                
                monthlySection.innerHTML += generateMultiBarHTML(`${t.monthlyData} (${year} in °C)`, mSeriesArrays, mLabels);
            });

            document.getElementById('monthly-title').style.display = 'block';
            monthlySection.style.display = 'block';

            // Smart Scrolling
            setTimeout(() => {
                document.querySelectorAll('.history-chart-grid').forEach(chart => {
                    const labels = chart.querySelectorAll('.chart-label');
                    let targetCol = null;
                    
                    for (let i = labels.length - 1; i >= 0; i--) {
                        if (labels[i].innerText.trim() !== '') {
                            targetCol = labels[i];
                            break;
                        }
                    }
                    if (targetCol) {
                        const scrollAmount = targetCol.getBoundingClientRect().right - chart.getBoundingClientRect().right;
                        if (scrollAmount > 0) chart.scrollLeft += scrollAmount + 16;
                    } else {
                        chart.scrollLeft = chart.scrollWidth;
                    }
                });
            }, 100);

        }).catch(e => {
            document.getElementById('loading').style.display = 'none';
            document.getElementById('error').style.display = 'block';
            document.getElementById('error').innerText = t.errorNet;
        });

    </script>
</body>
</html>

<style is:global>
    :root {
        --bg: #030303;
        --card-bg: rgba(14, 14, 14, 0.65);
        --card-border: rgba(214, 175, 55, 0.09);
        --card-border-hover: rgba(214, 175, 55, 0.25);
        --accent: #ca9f1b;
        --success: #10b981;
        --text-main: #f3f4f6;
        --text-muted: #4b5563;
        --text-dim: #9ca3af;
    }

    #weather-bg {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
        background-size: cover; background-position: center center;
        background-repeat: no-repeat; transition: filter 3s ease;
    }

    .floating-back {
        position: fixed; top: max(1.5rem, env(safe-area-inset-top)); left: max(1.5rem, env(safe-area-inset-left));
        z-index: 999; display: flex; align-items: center; gap: 0.5rem;
        background: rgba(14, 14, 14, 0.65); border: 1px solid rgba(255, 255, 255, 0.09);
        backdrop-filter: blur(20px); padding: 0.5rem 1rem 0.5rem 0.5rem; border-radius: 100px;
        color: var(--text-main); font-size: 0.8rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1); cursor: pointer;
    }
    .floating-back:hover { border-color: rgba(214, 175, 55, 0.25); background: rgba(255, 255, 255, 0.05); transform: scale(1.02); }
    .floating-back:active { transform: scale(0.96); }

    body {
        font-family: 'Plus Jakarta Sans', -apple-system, sans-serif; background-color: var(--bg);
        background-image: radial-gradient(circle at 0% 0%, rgba(214, 175, 55, 0.04), transparent 45%),
            radial-gradient(circle at 100% 100%, rgba(16, 185, 129, 0.02), transparent 45%),
            linear-gradient(to right, rgba(255, 255, 255, 0.01) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255, 255, 255, 0.01) 1px, transparent 1px);
        background-size: 100% 100%, 100% 100%, 64px 64px, 64px 64px; background-attachment: fixed;
        color: var(--text-main); margin: 0; min-height: 100vh; display: flex; flex-direction: column;
        align-items: center; padding: 5.5rem 2rem 4rem 2rem; box-sizing: border-box;
    }

    .container { max-width: 1100px; width: 100%; }
    header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding-bottom: 2rem; }
    .brand h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.04em; margin: 0; background: linear-gradient(135deg, #fff 50%, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .status-badge { display: flex; align-items: center; gap: 0.6rem;
        background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); padding: 0.5rem 1.2rem; border-radius: 100px; font-size: 0.75rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: #374151; position: relative; }
    .status-dot.online { background: var(--success); box-shadow: 0 0 12px var(--success); }
    .status-dot.online::after { content: ''; position: absolute; width: 100%; height: 100%; top: 0; left: 0; border-radius: 50%; background: var(--success); animation: pulse 2s infinite; }
    @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(3); opacity: 0; } }
    .section-title { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); margin: 2rem 0 1rem 0; font-weight: 700; width: 100%; }
    .bento-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem; margin-bottom: 1.25rem; width: 100%; }
    .col-12 { grid-column: span 12; }
    .card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 1rem; padding: 1.75rem; backdrop-filter: blur(20px); position: relative; overflow: hidden; display: flex; flex-direction: column; cursor: default; }
    .card.clickable { cursor: pointer; transition: background 0.2s, transform 0.2s, border-color 0.4s; }
    .card.clickable:hover { background: rgba(255, 255, 255, 0.03); border-color: var(--card-border-hover); box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.7); }
    .card.clickable:active { transform: scale(0.98); }
    .card-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: #52525b; font-weight: 700; margin-bottom: 1.25rem; }
    
    .history-chart-grid { display: flex; flex-wrap: nowrap; gap: 0.75rem; min-height: 140px; align-items: flex-end; padding-top: 1rem; overflow-x: auto; overflow-y: hidden; padding-bottom: 0.5rem; scrollbar-width: thin; scrollbar-color: rgba(255, 255, 255, 0.1) transparent; }
    .history-chart-grid::-webkit-scrollbar { height: 6px; }
    .history-chart-grid::-webkit-scrollbar-track { background: transparent; }
    .history-chart-grid::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 4px; }
    .history-chart-grid::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.25); }
    
    .chart-column { display: flex; flex-direction: column; align-items: center; justify-content: flex-end; min-width: 45px; max-width: 75px; flex: 1 1 0; }
    .chart-bar-container { width: 100%; height: 120px; background: rgba(255,255,255,0.01); border-radius: 4px; display: flex; align-items: flex-end; overflow: hidden; border: 1px solid rgba(255,255,255,0.02); }
    .chart-bar { width: 100%; border-radius: 3px 3px 0 0; transition: height 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .chart-value { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-dim); font-weight: 700; margin: 0.4rem 0 0.15rem 0; white-space: nowrap; }
    .chart-label { font-size: 0.7rem; text-transform: uppercase; color: #52525b; font-weight: 700; letter-spacing: 0.05em; }

    @media (max-width: 768px) { header { flex-direction: column; align-items: flex-start; gap: 1rem; } }
</style>