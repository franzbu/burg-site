---
// src/pages/temp-stats.astro
const acceptLang = Astro.request.headers.get('accept-language') || 'de';
const prefs = acceptLang.toLowerCase().split(',').map(l => l.trim().substring(0, 2));
const lang = prefs.find(l => ['de', 'en', 'it'].includes(l)) || 'de';

const trans = {
    de: {
        title: "Burg | Historische Daten", head: "Burg - Historische Daten (LTS)", loadData: "Lade Daten...",
        init: "INITIALISIERE...", loadingStats: "Rufe Langzeitstatistiken ab...", back: "Zurück",
        online: "VERBUNDEN", errorNet: "Netzwerkfehler.", errorPrefix: "Fehler: ",
        last24Hours: "⏱️ Letzte 24 Stunden",
        last15Days: "📅 Letzte 15 Tage (Tageswerte in", histData: "📈 Historische Daten (LTS)",
        monthlyData: "📅 Monatswerte",
        monthsShort: ['Jan', 'Feb', 'Mär', 'Apr', 'Mai', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez'],
        entities: {
            'sensor.weather_sensor_plus_garten_temperature': { name: 'Außentemperatur', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_north_temperature': { name: 'Nord-Fassade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_balkon_temperature': { name: 'Süd-Fassade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_house_east_temperature': { name: 'Ost-Fassade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_house_west_temperature': { name: 'West-Fassade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_west_temperature': { name: 'West-Fassade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_garten_temperature': { name: 'Gewächshaus (Temperatur)', unit: '°' },
            'sensor.weather_sensor_plus_garten_wind_speed': { name: 'Windgeschwindigkeit', unit: ' km/h' },
            'sensor.weather_sensor_plus_garten_humidity': { name: 'Luftfeuchtigkeit', unit: '%' },
            'sensor.weather_sensor_plus_garten_total_sunshine_duration': { name: 'Sonnenscheindauer', unit: ' min' },
            'sensor.switching_and_measuring_cable_outdoor_energy_counter': { name: 'Heizenergie (Gewächshaus)', unit: ' kWh' }
        }
    },
    en: {
        title: "Burg | Historical Data", head: "Burg - Historical Data (LTS)", loadData: "Loading Data...",
        init: "INITIALIZING...", loadingStats: "Fetching long-term statistics...", back: "Back",
        online: "CONNECTED", errorNet: "Network Error.", errorPrefix: "Error: ",
        last24Hours: "⏱️ Last 24 Hours",
        last15Days: "📅 Last 15 Days (Daily values in", histData: "📈 Historical Data (LTS)",
        monthlyData: "📅 Monthly Values",
        monthsShort: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
        entities: {
            'sensor.weather_sensor_plus_garten_temperature': { name: 'Outdoor Temperature', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_north_temperature': { name: 'North Facade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_balkon_temperature': { name: 'South Facade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_house_east_temperature': { name: 'East Facade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_house_west_temperature': { name: 'West Facade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_west_temperature': { name: 'West Facade', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_garten_temperature': { name: 'Greenhouse (Temperature)', unit: '°' },
            'sensor.weather_sensor_plus_garten_wind_speed': { name: 'Wind Speed', unit: ' km/h' },
            'sensor.weather_sensor_plus_garten_humidity': { name: 'Humidity', unit: '%' },
            'sensor.weather_sensor_plus_garten_total_sunshine_duration': { name: 'Sunshine Duration', unit: ' min' },
            'sensor.switching_and_measuring_cable_outdoor_energy_counter': { name: 'Heating Energy (Greenhouse)', unit: ' kWh' }
        }
    },
    it: {
        title: "Burg | Dati Storici", head: "Burg - Dati Storici (LTS)", loadData: "Caricamento Dati...",
        init: "INIZIALIZZAZIONE...", loadingStats: "Recupero statistiche a lungo termine...", back: "Indietro",
        online: "CONNESSO", errorNet: "Errore di Rete.", errorPrefix: "Errore: ",
        last24Hours: "⏱️ Ultime 24 Ore",
        last15Days: "📅 Ultimi 15 Giorni (Valori giornalieri in", histData: "📈 Dati Storici (LTS)",
        monthlyData: "📅 Valori Mensili",
        monthsShort: ['Gen', 'Feb', 'Mar', 'Apr', 'Mag', 'Giu', 'Lug', 'Ago', 'Set', 'Ott', 'Nov', 'Dic'],
        entities: {
            'sensor.weather_sensor_plus_garten_temperature': { name: 'Temperatura Esterna', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_north_temperature': { name: 'Facciata Nord', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_balkon_temperature': { name: 'Facciata Sud', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_house_east_temperature': { name: 'Facciata Est', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_house_west_temperature': { name: 'Facciata Ovest', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_west_temperature': { name: 'Facciata Ovest', unit: '°' },
            'sensor.temperature_and_humidity_sensor_outdoor_garten_temperature': { name: 'Serra (Temperatura)', unit: '°' },
            'sensor.weather_sensor_plus_garten_wind_speed': { name: 'Velocità Vento', unit: ' km/h' },
            'sensor.weather_sensor_plus_garten_humidity': { name: 'Umidità', unit: '%' },
            'sensor.weather_sensor_plus_garten_total_sunshine_duration': { name: 'Durata Sole', unit: ' min' },
            'sensor.switching_and_measuring_cable_outdoor_energy_counter': { name: 'Energia Riscaldamento (Serra)', unit: ' kWh' }
        }
    }
};
const t = trans[lang];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{t.title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M18 20V10h2v10h-2M4 20V10h2v10H4m9-10v2h-2v-2h2m1-8l2 2v2h-2V2l-2 2-2-2v2H7V4L5 2v4h14V2l-2 2zM21 9h-2V7h-2v2h-2V7h-2v2h-2V7H9v2H7V7H5v2H3v12h18V9z'/></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><rect width='24' height='24' fill='black'/><path d='M18 20V10h2v10h-2M4 20V10h2v10H4m9-10v2h-2v-2h2m1-8l2 2v2h-2V2l-2 2-2-2v2H7V4L5 2v4h14V2l-2 2zM21 9h-2V7h-2v2h-2V7h-2v2h-2V7H9v2H7V7H5v2H3v12h18V9z'/></svg>">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#030303">
</head>
<body>
    
    <div class="floating-back clickable" onclick="if(window.opener){window.close();}else{window.location.href='/';}">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        <span>{t.back}</span>
    </div>

    <div id="weather-bg" style="background-image: url('/garten_bg.webp');"></div>

    <div class="container">
        <header>
            <div class="brand">
                <h1>{t.head}</h1>
                <p id="sensor-name" style="color: var(--accent); font-weight: 700; font-size: 0.95rem;">{t.loadData}</p>
            </div>
            <div class="status-badge">
                <div id="status-indicator" class="status-dot"></div>
                <span id="status-text">{t.init}</span>
            </div>
        </header>

        <p id="loading" style="color: #9ca3af; font-family: 'JetBrains Mono', monospace;">{t.loadingStats}</p>
        <p id="error" style="display:none; color: #ef4444; font-family: 'JetBrains Mono', monospace;"></p>

        <div id="content" style="display:none;">
            <div class="bento-grid" id="hourly-section" style="display:none;">
                <div class="card col-12">
                    <div class="card-title" id="hourly-title-text"></div>
                    <div class="history-chart-grid" id="hourlyChart"></div>
                </div>
            </div>

            <div class="bento-grid" id="daily-section" style="display:none;">
                <div class="card col-12">
                    <div class="card-title" id="daily-title-text"></div>
                    <div class="history-chart-grid" id="dailyChart"></div>
                </div>
            </div>

            <h2 class="section-title" id="monthly-title" style="display:none;">{t.histData}</h2>
            <div class="bento-grid" id="monthly-section" style="display:none;"></div>
        </div>
    </div>

    <script is:inline set:html={`const t = ${JSON.stringify(t)};`}></script>
    <script is:inline>
        const statusDot = document.getElementById('status-indicator');
        const statusText = document.getElementById('status-text');
        const weatherBg = document.getElementById('weather-bg');

        const urlParams = new URLSearchParams(window.location.search);
        const entity = urlParams.get('entity_id');
        const entityMap = t.entities;
        const entityInfo = entityMap[entity] || { name: entity, unit: '' };
        document.getElementById('sensor-name').innerText = entityInfo.name;

        function applyWeatherTone(lux, isRaining) {
            if (!weatherBg) return;
            const brightness = 0.3 + (Math.log10(Math.max(1, lux)) / 4.5) * 0.7;
            const saturation = 0.4 + (Math.log10(Math.max(1, lux)) / 4.5) * 0.7;
            let filterString = `brightness(${Math.min(1.2, brightness).toFixed(2)}) saturate(${Math.min(1.3, saturation).toFixed(2)}) blur(${isRaining ? 8 : 5}px)`;
            if (isRaining) filterString += ` contrast(0.85) sepia(0.15) hue-rotate(185deg)`;
            weatherBg.style.filter = filterString;
        }

        fetch('/api/status').then(r => r.json()).then(data => {
            if (data.weather_station) applyWeatherTone(data.weather_station.lux || 0, data.weather_station.is_raining);
        });

        if(entity) {
            fetch(`/api/temperature?entity_id=${entity}`)
            .then(r => r.json())
            .then(data => {
                document.getElementById('loading').style.display = 'none';
                if (data.error) {
                    document.getElementById('error').innerText = t.errorPrefix + data.error;
                    document.getElementById('error').style.display = 'block';
                    return;
                }

                document.getElementById('content').style.display = 'block';
                statusDot.className = "status-dot online";
                statusText.innerText = t.online;

                const cleanUnit = entityInfo.unit.trim();
                const unitSuffix = cleanUnit === '°' ? '°' : '';
                const isHumidity = entity === 'sensor.weather_sensor_plus_garten_humidity';
                
                const hideBarMinMax = entity === 'sensor.switching_and_measuring_cable_outdoor_energy_counter' || 
                                      entity === 'sensor.weather_sensor_plus_garten_total_sunshine_duration';
                
                const allowedHourlyEntities = [
                    'sensor.weather_sensor_plus_garten_temperature',
                    'sensor.temperature_and_humidity_sensor_outdoor_north_temperature',
                    'sensor.temperature_and_humidity_sensor_outdoor_balkon_temperature',
                    'sensor.temperature_and_humidity_sensor_outdoor_house_east_temperature',
                    'sensor.temperature_and_humidity_sensor_outdoor_house_west_temperature',
                    'sensor.temperature_and_humidity_sensor_outdoor_west_temperature',
                    'sensor.temperature_and_humidity_sensor_outdoor_garten_temperature',
                    'sensor.weather_sensor_plus_garten_wind_speed',
                    'sensor.weather_sensor_plus_garten_humidity'
                ];

                if (allowedHourlyEntities.includes(entity) && data.hourly && data.hourly.length > 0) {
                    const hChart = document.getElementById('hourlyChart');
                    hChart.style.display = 'block';
                    hChart.style.paddingTop = '0';
                    
                    const points = data.hourly;
                    const realMaxH = Math.max(...points.map(d => d.max !== null && d.max !== undefined ? d.max : d.mean));
                    const realMinH = Math.min(...points.map(d => d.min !== null && d.min !== undefined ? d.min : d.mean));
                    let maxValH = realMaxH;
                    let minValH = realMinH;
                    
                    document.getElementById('hourly-title-text').innerHTML = `${t.last24Hours} (in ${cleanUnit}) <span style="float:right; font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); text-transform:none;">Min: ${realMinH.toFixed(1)}${unitSuffix} | Max: ${realMaxH.toFixed(1)}${unitSuffix}</span>`;

                    const padding = (maxValH - minValH) * 0.1 || 1;
                    maxValH += padding;
                    minValH -= padding;
                    const rangeH = maxValH - minValH || 1;

                    const svgWidth = 800;
                    const svgHeight = 140;
                    
                    const getY = (temp) => svgHeight - (((temp - minValH) / rangeH) * svgHeight);

                    let pathD = "";
                    let fillD = "";

                    points.forEach((point, i) => {
                        const x = (i / (points.length - 1)) * svgWidth;
                        const y = getY(point.mean);
                        if (i === 0) {
                            pathD += `M ${x} ${y} `;
                            fillD += `M ${x} ${svgHeight} L ${x} ${y} `;
                        } else {
                            pathD += `L ${x} ${y} `;
                            fillD += `L ${x} ${y} `;
                        }
                    });
                    fillD += `L ${svgWidth} ${svgHeight} Z`;

                    let labelsHTML = '';
                    const numLabels = 24;
                    
                    for (let i = 0; i < numLabels; i++) {
                        const pointIdx = Math.floor((i / (numLabels - 1)) * (points.length - 1));
                        const val = points[pointIdx] ? points[pointIdx].mean.toFixed(1) : '--.-';
                        const hr = points[pointIdx] ? new Date(points[pointIdx].start).getHours() : '';
                        labelsHTML += `
                            <div style="display: flex; flex-direction: column; align-items: center; flex: 1;">
                                <div class="chart-value" style="margin-top: 0.25rem;">${val}</div>
                                <div class="chart-label">${hr}</div>
                            </div>
                        `;
                    }

                    hChart.innerHTML = `
                        <div style="width: 100%; min-width: 1200px; display: flex; flex-direction: column;">
                            <svg viewBox="0 0 ${svgWidth} ${svgHeight}" preserveAspectRatio="none" style="width: 100%; height: 140px; overflow: visible;">
                                <defs>
                                    ${isHumidity ? `
                                    <linearGradient id="chartGrad" x1="0" y1="${getY(100)}" x2="0" y2="${getY(0)}" gradientUnits="userSpaceOnUse">
                                        <stop offset="0%" stop-color="#ffffff" />     <stop offset="50%" stop-color="#f8fafc" />    <stop offset="100%" stop-color="#cbd5e1" />   </linearGradient>
                                    ` : `
                                    <linearGradient id="chartGrad" x1="0" y1="${getY(50)}" x2="0" y2="${getY(-20)}" gradientUnits="userSpaceOnUse">
                                        <stop offset="0%" stop-color="#7f1d1d" />     <stop offset="14.2%" stop-color="#dc2626" />  <stop offset="28.5%" stop-color="#ea580c" />  <stop offset="50%" stop-color="#fde047" />    <stop offset="71.3%" stop-color="#fef08a" />  <stop offset="71.4%" stop-color="#7dd3fc" />  <stop offset="100%" stop-color="#1e3a8a" />   </linearGradient>
                                    `}
                                    
                                    <linearGradient id="maskGrad" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="white" stop-opacity="0.4"/>
                                        <stop offset="100%" stop-color="white" stop-opacity="0.0"/>
                                    </linearGradient>
                                    
                                    <mask id="fadeMask">
                                        <rect x="0" y="0" width="${svgWidth}" height="${svgHeight}" fill="url(#maskGrad)" />
                                    </mask>
                                </defs>
                                <path d="${fillD}" fill="url(#chartGrad)" mask="url(#fadeMask)" />
                                <path d="${pathD}" fill="none" stroke="url(#chartGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <div style="display: flex; justify-content: space-between; margin-top: 5px; width: 100%;">
                                ${labelsHTML}
                            </div>
                        </div>
                    `;
                    document.getElementById('hourly-section').style.display = 'block';
                }

                if (data.daily && data.daily.length > 0) {
                    const dChart = document.getElementById('dailyChart');
                    const realMaxD = Math.max(...data.daily.map(d => d.max !== null && d.max !== undefined ? d.max : d.mean));
                    const realMinD = Math.min(...data.daily.map(d => d.min !== null && d.min !== undefined ? d.min : d.mean));
                    
                    document.getElementById('daily-title-text').innerHTML = `${t.last15Days} ${cleanUnit}) <span style="float:right; font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); text-transform:none;">Min: ${realMinD.toFixed(1)}${unitSuffix} | Max: ${realMaxD.toFixed(1)}${unitSuffix}</span>`;

                    let maxVal = Math.max(realMaxD, 1);
                    let minVal = Math.min(realMinD, 0);
                    if(minVal > 0) minVal = 0;
                    const range = maxVal - minVal || 1;
                    
                    const dailyBarBg = isHumidity ? 'linear-gradient(to top, rgba(255, 255, 255, 0.3), #ffffff)' : 'linear-gradient(to top, rgba(250, 204, 21, 0.2), #facc15)';

                    data.daily.forEach(point => {
                        const dateObj = new Date(point.start);
                        const label = `${dateObj.getDate().toString().padStart(2,'0')}.${(dateObj.getMonth()+1).toString().padStart(2,'0')}`;
                        const pct = point.mean === 0 ? 0 : Math.max(1, ((point.mean - minVal) / range) * 100);
                        
                        const maxText = (!hideBarMinMax && point.max !== undefined && point.max !== null) ? point.max.toFixed(1) + unitSuffix : '';
                        const minText = (!hideBarMinMax && point.min !== undefined && point.min !== null) ? point.min.toFixed(1) + unitSuffix : '';

                        dChart.innerHTML += `
                            <div class="chart-column">
                                <div class="chart-value" style="font-size: 0.65rem; color: #ef4444; margin-bottom: 0.1rem;">${maxText}</div>
                                <div class="chart-value" style="font-size: 0.65rem; color: #3b82f6; margin-bottom: 0.3rem; margin-top: 0;">${minText}</div>
                                <div class="chart-bar-container">
                                    <div class="chart-bar" style="height: ${pct}%; background: ${dailyBarBg}; opacity: 0.9;"></div>
                                </div>
                                <div class="chart-value">${point.mean.toFixed(1)}</div>
                                <div class="chart-label">${label}</div>
                            </div>
                        `;
                    });
                    document.getElementById('daily-section').style.display = 'block';
                }
                
                if (data.monthly && data.monthly.length > 0) {
                    const monthlySection = document.getElementById('monthly-section');
                    const archive = {};
                    let allMeans = [];
                    
                    data.monthly.forEach(point => {
                        const d = new Date(point.start);
                        const y = d.getFullYear();
                        const m = d.getMonth(); 
                        if (!archive[y]) archive[y] = new Array(12).fill(null);
                        archive[y][m] = { mean: point.mean, min: point.min, max: point.max };
                        allMeans.push(point.mean);
                    });

                    let maxM = Math.max(...allMeans, 1);
                    let minM = Math.min(...allMeans, 0);
                    if (minM > 0) minM = 0;
                    const rangeM = maxM - minM || 1;

                    const months = t.monthsShort;
                    const sortedYears = Object.keys(archive).sort((a, b) => b - a);
                    
                    const monthlyBarBg = isHumidity ? 'linear-gradient(to top, rgba(255, 255, 255, 0.15), #e2e8f0)' : 'linear-gradient(to top, rgba(249, 115, 22, 0.4), #ff8c00)';

                    sortedYears.forEach(year => {
                        const validMins = archive[year].filter(v => v !== null && v.min !== null && v.min !== undefined).map(v => v.min);
                        const validMaxs = archive[year].filter(v => v !== null && v.max !== null && v.max !== undefined).map(v => v.max);
                        
                        const yMin = validMins.length > 0 ? Math.min(...validMins).toFixed(1) : '--.-';
                        const yMax = validMaxs.length > 0 ? Math.max(...validMaxs).toFixed(1) : '--.-';
                        const yMinText = yMin + (yMin !== '--.-' ? unitSuffix : '');
                        const yMaxText = yMax + (yMax !== '--.-' ? unitSuffix : '');
                        
                        let html = `
                            <div class="card col-12" style="margin-bottom: 20px;">
                                <div class="card-title">${t.monthlyData} (${year} in ${cleanUnit}) <span style="float:right; font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); text-transform:none;">Min: ${yMinText} | Max: ${yMaxText}</span></div>
                                <div class="history-chart-grid">
                        `;

                        archive[year].forEach((dataObj, index) => {
                            const hasData = dataObj !== null;
                            if (!hasData) return; // Completely erase month if no data exists for sensor

                            const pct = (dataObj.mean === 0) ? 0 : Math.max(1, ((dataObj.mean - minM) / rangeM) * 100);
                            
                            const meanText = dataObj.mean.toFixed(1);
                            const maxText = (!hideBarMinMax && dataObj.max !== undefined && dataObj.max !== null) ? dataObj.max.toFixed(1) + unitSuffix : '';
                            const minText = (!hideBarMinMax && dataObj.min !== undefined && dataObj.min !== null) ? dataObj.min.toFixed(1) + unitSuffix : '';

                            html += `
                                <div class="chart-column">
                                    <div class="chart-value" style="font-size: 0.65rem; color: #ef4444; margin-bottom: 0.1rem;">${maxText}</div>
                                    <div class="chart-value" style="font-size: 0.65rem; color: #3b82f6; margin-bottom: 0.3rem; margin-top: 0;">${minText}</div>
                                    <div class="chart-bar-container">
                                        <div class="chart-bar" style="height: ${pct}%; background: ${monthlyBarBg}; opacity: 0.9;"></div>
                                    </div>
                                    <div class="chart-value">${meanText}</div>
                                    <div class="chart-label">${months[index]}</div>
                                </div>
                            `;
                        });

                        html += `</div></div>`;
                        monthlySection.innerHTML += html;
                    });

                    document.getElementById('monthly-title').style.display = 'block';
                    monthlySection.style.display = 'block';
                }

                setTimeout(() => {
                    document.querySelectorAll('.history-chart-grid').forEach(chart => {
                        const labels = chart.querySelectorAll('.chart-label');
                        let targetCol = null;
                        
                        for (let i = labels.length - 1; i >= 0; i--) {
                            if (labels[i].innerText.trim() !== '') {
                                targetCol = labels[i];
                                break;
                            }
                        }
                        
                        if (targetCol) {
                            const scrollAmount = targetCol.getBoundingClientRect().right - chart.getBoundingClientRect().right;
                            if (scrollAmount > 0) chart.scrollLeft += scrollAmount + 16;
                        } else {
                            chart.scrollLeft = chart.scrollWidth;
                        }
                    });
                }, 100);

            }).catch(e => {
                document.getElementById('loading').style.display = 'none';
                document.getElementById('error').style.display = 'block';
                document.getElementById('error').innerText = t.errorNet;
            });
        }
    </script>
</body>
</html>

<style is:global>
