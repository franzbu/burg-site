---
// Burg | Live-Betriebszentrum Frontend
const acceptLang = Astro.request.headers.get('accept-language') || 'de';
const prefs = acceptLang.toLowerCase().split(',').map(l => l.trim().substring(0, 2));
const lang = prefs.find(l => ['de', 'en', 'it'].includes(l)) || 'de';

const trans = {
    de: {
        title: "Burg | Klimadaten", head: "Burg - Klimadaten", live: "Live-Betriebszentrum",
        init: "INITIALISIERE...", loading: "LÄDT...", outdoor: "☀️ Außentemperatur",
        sysAvg: "System-Mittel", brightness: "Helligkeit", facades: "🏛️ Hausfassaden",
        north: "Nord-Fassade", south: "Süd-Fassade", east: "Ost-Fassade", west: "West-Fassade",
        greenhouse: "🌿 Gewächshaus", watchdog: "Heizungs-Watchdog", heatingEnergy: "Heizenergie",
        rainToday: "🌧️ Niederschlag (Heute)", rainYesterday: "Regen Gestern", meteoStatus: "Meteo-Status",
        irrigationToday: "💦 Gartenberegnung", irrigationYesterday: "Gestern", circuitState: "Ventil-Status",
        sunshineToday: "⏱️ Sonnenscheindauer (Heute)", sensorType: "Sensor-Typ", optical: "Optisch",
        threshold: "Schwelle", stateVectors: "⚡ Sensor-Zustandsvektoren", acuteRain: "Akuter Niederschlag",
        stormDetect: "Sturmwahrnehmung", windSpeed: "💨 Windgeschwindigkeit", humidity: "Luftfeuchtigkeit",
        online: "WETTERSTATION ONLINE", error: "KONNEKTIVITÄTSFEHLER",
        storm: "STURM", rain: "REGEN", clear: "KLAR", yes: "JA", no: "NEIN", on: "EIN", off: "AUS",
        panorama: "⛰️ Panorama"
    },
    en: {
        title: "Burg | Climate Data", head: "Burg - Climate Data", live: "Live Operations Center",
        init: "INITIALIZING...", loading: "LOADING...", outdoor: "☀️ Outdoor Temperature",
        sysAvg: "System Average", brightness: "Brightness", facades: "🏛️ House Facades",
        north: "North Facade", south: "South Facade", east: "East Facade", west: "West Facade",
        greenhouse: "🌿 Greenhouse", watchdog: "Heating Watchdog", heatingEnergy: "Heating Energy",
        rainToday: "🌧️ Precipitation (Today)", rainYesterday: "Rain Yesterday", meteoStatus: "Meteo Status",
        irrigationToday: "💦 Garden Irrigation", irrigationYesterday: "Yesterday", circuitState: "Valve Status",
        sunshineToday: "⏱️ Sunshine Duration (Today)", sensorType: "Sensor Type", optical: "Optical",
        threshold: "Threshold", stateVectors: "⚡ Sensor State Vectors", acuteRain: "Acute Rain",
        stormDetect: "Storm Detection", windSpeed: "💨 Wind Speed", humidity: "Humidity",
        online: "WEATHER STATION ONLINE", error: "CONNECTION ERROR",
        storm: "STORM", rain: "RAIN", clear: "CLEAR", yes: "YES", no: "NO", on: "ON", off: "OFF",
        panorama: "⛰️ Panorama"
    },
    it: {
        title: "Burg | Dati Climatici", head: "Burg - Dati Climatici", live: "Centro Operativo Live",
        init: "INIZIALIZZAZIONE...", loading: "CARICAMENTO...", outdoor: "☀️ Temperatura Esterna",
        sysAvg: "Media di Sistema", brightness: "Luminosità", facades: "🏛️ Facciate",
        north: "Facciata Nord", south: "Facciata Sud", east: "Facciata Est", west: "Facciata Ovest",
        greenhouse: "🌿 Serra", watchdog: "Watchdog Riscaldamento", heatingEnergy: "Energia Riscaldamento",
        rainToday: "🌧️ Precipitazioni (Oggi)", rainYesterday: "Pioggia Ieri", meteoStatus: "Stato Meteo",
        irrigationToday: "💦 Irrigazione Giardino", irrigationYesterday: "Ieri", circuitState: "Stato Valvola",
        sunshineToday: "⏱️ Durata Sole (Oggi)", sensorType: "Tipo Sensore", optical: "Ottico",
        threshold: "Soglia", stateVectors: "⚡ Vettori di Stato", acuteRain: "Pioggia in Corso",
        stormDetect: "Rilevamento Tempesta", windSpeed: "💨 Velocità Vento", humidity: "Umidità",
        online: "STAZIONE METEO ONLINE", error: "ERRORE DI CONNESSIONE",
        storm: "TEMPESTA", rain: "PIOGGIA", clear: "SERENO", yes: "SÌ", no: "NO", on: "ON", off: "OFF",
        panorama: "⛰️ Panorama"
    }
};
const t = trans[lang];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{t.title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><path d='M18 20V10h2v10h-2M4 20V10h2v10H4m9-10v2h-2v-2h2m1-8l2 2v2h-2V2l-2 2-2-2v2H7V4L5 2v4h14V2l-2 2zM21 9h-2V7h-2v2h-2V7h-2v2h-2V7H9v2H7V7H5v2H3v12h18V9z'/></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ca9f1b'><rect width='24' height='24' fill='black'/><path d='M18 20V10h2v10h-2M4 20V10h2v10H4m9-10v2h-2v-2h2m1-8l2 2v2h-2V2l-2 2-2-2v2H7V4L5 2v4h14V2l-2 2zM21 9h-2V7h-2v2h-2V7h-2v2h-2V7H9v2H7V7H5v2H3v12h18V9z'/></svg>">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#030303">
</head>
<body>

    <div id="weather-bg" style="background-image: url('/background.webp');"></div>

    <div class="container">
    
        <header>
            <div class="brand">
                <h1>{t.head}</h1>
                <p id="system-time">{t.live}</p>
            </div>
            <div class="status-badge">
                <div id="status-indicator" class="status-dot"></div>
                <span id="status-text">{t.init}</span>
            </div>
        </header>
        
        <div class="bento-grid">
            
            <div class="card col-4 clickable" onclick="openPanoramaStats()">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.25rem;">
                    <div class="card-title" style="margin-bottom: 0;">{t.panorama}</div>
                    <div id="panorama-time" style="font-size: 0.65rem; color: var(--text-dim); font-family: 'JetBrains Mono', monospace;"></div>
                </div>
                <div id="panorama-container" style="flex: 1; width: 100%; border-radius: 8px; overflow: hidden; background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; min-height: 120px; position: relative;">
                    <img id="latest-panorama-img" style="width: 100%; height: 100%; object-fit: cover; display: none; position: absolute; top: 0; left: 0;">
                    <span id="panorama-loading" style="font-size: 0.7rem; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; z-index: 1;">{t.loading}</span>
                </div>
            </div>
            
            <div class="card col-4 clickable" onclick="openTempStats('sensor.weather_sensor_plus_garten_temperature')">
                <div class="card-title">{t.outdoor}</div>
                <div class="value-large" id="ws-temp">--.-<span class="value-unit">°C</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">{t.sysAvg}</div>
                        <div class="sub-value" id="computed-avg" style="color: var(--accent);">--.- °C</div>
                    </div>
                    <div>
                        <div class="sub-label">{t.brightness}</div>
                        <div class="sub-value" id="ws-lux">-- lx</div>
                    </div>
                </div>
            </div>

            <div class="card col-4">
                <div class="card col-4">
                <div class="card-title">{t.facades}</div>
                <div style="margin: auto 0; width: 100%;">
                    <div class="facade-row clickable" onclick="openTempStats('sensor.temperature_and_humidity_sensor_outdoor_north_temperature')">
                        <span class="facade-name">{t.north}</span>
                        <span class="facade-val" id="facade-north">--.-°C</span>
                    </div>
                    <div class="facade-row clickable" onclick="openTempStats('sensor.temperature_and_humidity_sensor_outdoor_balkon_temperature')">
                        <span class="facade-name">{t.south}</span>
                        <span class="facade-val" id="facade-south">--.-°C</span>
                    </div>
                    <div class="facade-row clickable" onclick="openTempStats('sensor.temperature_and_humidity_sensor_outdoor_house_east_temperature')">
                        <span class="facade-name">{t.east}</span>
                        <span class="facade-val" id="facade-east">--.-°C</span>
                    </div>
                    <div class="facade-row clickable" onclick="openTempStats('sensor.temperature_and_humidity_sensor_outdoor_west_temperature')">
                        <span class="facade-name">{t.west}</span>
                        <span class="facade-val" id="facade-west">--.-°C</span>
                    </div>
                </div>
            </div>
            </div>

            <div class="card col-4" style="background: radial-gradient(circle at 100% 0%, rgba(16, 185, 129, 0.04), transparent 60%), var(--card-bg); padding: 0; display: flex; flex-direction: column; overflow: hidden;">
                <div class="clickable" onclick="openTempStats('sensor.temperature_and_humidity_sensor_outdoor_garten_temperature')" style="flex: 1; padding: 1.75rem; padding-bottom: 1.25rem; display: flex; flex-direction: column;">
                    <div class="card-title" style="color: var(--success);">{t.greenhouse}</div>
                    <div class="value-large" id="facade-greenhouse">--.-<span class="value-unit" style="color: var(--success);">°C</span></div>
                </div>
                <div class="clickable" onclick="openTempStats('sensor.switching_and_measuring_cable_outdoor_energy_counter')" style="padding: 1.25rem 1.75rem; border-top: 1px solid rgba(255, 255, 255, 0.04); display: flex; flex-direction: column; flex: 1;">
                    <div class="sub-metrics" style="border-color: rgba(16, 185, 129, 0.1); margin: auto 0; border-top: none; padding-top: 0;">
                        <div>
                            <div class="sub-label">{t.watchdog}</div>
                            <div class="sub-value" id="ws-watchdog" style="color: var(--text-dim);">{t.loading}</div>
                        </div>
                        <div>
                            <div class="sub-label">{t.heatingEnergy}</div>
                            <div class="sub-value" id="ws-heater-energy">--.- kWh</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card col-4 clickable" onclick="openRainStats()">
                <div class="card-title">{t.rainToday}</div>
                <div class="value-large" id="ws-rain-today">--.-<span class="value-unit">mm</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">{t.rainYesterday}</div>
                        <div class="sub-value" id="ws-rain-yesterday">--.- mm</div>
                    </div>
                    <div>
                        <div class="sub-label">{t.meteoStatus}</div>
                        <div class="sub-value" id="ws-meteo-status">--</div>
                    </div>
                </div>
            </div>
            
            <div class="card col-4 clickable" onclick="openIrrigationStats()">
                <div class="card-title">{t.irrigationToday}</div>
                <div class="value-large" id="ws-irrigation-today">--.-<span class="value-unit">m</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">{t.irrigationYesterday}</div>
                        <div class="sub-value" id="ws-irrigation-yesterday">--.- m</div>
                    </div>
                    <div>
                        <div class="sub-label">{t.circuitState}</div>
                        <div class="sub-value" id="ws-irrigation-state">--</div>
                    </div>
                </div>
            </div>

            <div class="card col-4 clickable" onclick="openTempStats('sensor.weather_sensor_plus_garten_total_sunshine_duration')">
                <div class="card-title">{t.sunshineToday}</div>
                <div class="value-large" id="ws-sunshine">--<span class="value-unit">h</span> --<span class="value-unit">m</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">{t.sensorType}</div>
                        <div class="sub-value">{t.optical}</div>
                    </div>
                    <div>
                        <div class="sub-label">{t.threshold}</div>
                        <div class="sub-value">> 120 W/m²</div>
                    </div>
                </div>
            </div>

            <div class="card col-4">
                <div class="card-title">{t.stateVectors}</div>
                <div style="margin: auto 0; width: 100%;">
                    <div class="facade-row">
                        <span class="facade-name">{t.acuteRain}</span>
                        <span class="facade-val" id="ws-flag-raining">--</span>
                    </div>
                    <div class="facade-row">
                        <span class="facade-name">{t.stormDetect}</span>
                        <span class="facade-val" id="ws-flag-storm">--</span>
                    </div>
                </div>
            </div>

            <div class="card col-4" style="padding: 0; display: flex; flex-direction: column; overflow: hidden;">
                <div class="clickable" onclick="openTempStats('sensor.weather_sensor_plus_garten_wind_speed')" style="flex: 1; padding: 1.75rem; padding-bottom: 1.25rem; display: flex; flex-direction: column;">
                    <div class="card-title">{t.windSpeed}</div>
                    <div class="value-large" id="ws-wind">--.-<span class="value-unit">km/h</span></div>
                </div>
                <div class="clickable" onclick="openTempStats('sensor.weather_sensor_plus_garten_humidity')" style="padding: 1.25rem 1.75rem; border-top: 1px solid rgba(255, 255, 255, 0.04); display: flex; flex-direction: column; flex: 1;">
                    <div class="sub-metrics" style="margin: auto 0; border-top: none; padding-top: 0;">
                        <div>
                            <div class="sub-label">{t.humidity}</div>
                            <div class="sub-value" id="ws-hum">-- %</div>
                        </div>
                        <div></div>
                    </div>
                </div>
            </div>

        </div>

        <footer>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; width: 100%; color: black;">burg@gitor.uk</div>
        </footer>
    </div>

    <script is:inline set:html={`const t = ${JSON.stringify(t)};`}></script>
    <script is:inline>
        const statusDot = document.getElementById('status-indicator');
        const statusText = document.getElementById('status-text');
        const weatherBg = document.getElementById('weather-bg');
        const workerUrl = "https://burg-proxy.gitor.uk";
        
        let lastUpdateStr = "";

        function openTempStats(entityId) { window.open(`/temp-stats?entity_id=${entityId}`, '_blank'); }
        function openRainStats() { window.open(`/rain-stats`, '_blank'); }
        function openIrrigationStats() { window.open(`/irrigation-stats`, '_blank'); }
        function openPanoramaStats() { window.open(`/panorama`, '_blank'); }

        function formatSunshine(minutesTotal) {
            const h = Math.floor(minutesTotal / 60);
            const m = minutesTotal % 60;
            return `${h}<span class="value-unit">h</span> ${m}<span class="value-unit">m</span>`;
        }

        function applyWeatherTone(lux, isRaining) {
            if (!weatherBg) return;
            const brightness = 0.3 + (Math.log10(Math.max(1, lux)) / 4.5) * 0.7;
            const saturation = 0.4 + (Math.log10(Math.max(1, lux)) / 4.5) * 0.7;
            const blurValue = isRaining ? 8 : 5;
            let filterString = `brightness(${Math.min(1.2, brightness).toFixed(2)}) saturate(${Math.min(1.3, saturation).toFixed(2)}) blur(${blurValue}px)`;
            if (isRaining) filterString += ` contrast(0.85) sepia(0.15) hue-rotate(185deg)`;
            weatherBg.style.filter = filterString;
        }

        async function fetchLatestCameras() {
            try {
                const res = await fetch(`${workerUrl}/history`);
                if (!res.ok) throw new Error("Worker returned " + res.status);
                const files = await res.json();
                const mountainFiles = files.filter(f => f.name.startsWith('mountain_'));
                if (mountainFiles.length > 0) {
                    const img = document.getElementById('latest-panorama-img');
                    const params = "width=600,quality=75,format=auto";
                    img.src = `${workerUrl}/cdn-cgi/image/${params}/${mountainFiles[0].name}`;
                    
                    img.style.display = 'block';
                    document.getElementById('panorama-loading').style.display = 'none';
                    document.getElementById('panorama-time').innerText = new Date(mountainFiles[0].time).toLocaleString('de-DE');
                } else {
                    document.getElementById('panorama-loading').innerText = "--";
                    document.getElementById('panorama-time').innerText = "";
                }
            } catch (e) { 
                console.error("Camera tile error:", e);
                document.getElementById('panorama-loading').innerText = "ERROR";
            }
        }

        async function fetchStatus() {
            try {
                const res = await fetch('/api/status');
                const data = await res.json();
                if (data.error) throw new Error(data.error);
                
                lastUpdateStr = new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
                statusDot.className = "status-dot online";
                statusText.innerText = t.online;
                let tempsForAvg = [];
                if (data.weather_station) {
                    const ws = data.weather_station;
                    applyWeatherTone(ws.lux || 0, ws.is_raining);
                    if (ws.temp != null) {
                        tempsForAvg.push(ws.temp);
                        document.getElementById('ws-temp').innerHTML = `${ws.temp.toFixed(1)}<span class="value-unit">°C</span>`;
                    }
                    document.getElementById('ws-hum').innerText = ws.hum != null ? `${Math.round(ws.hum)} %` : '-- %';
                    document.getElementById('ws-wind').innerHTML = ws.wind != null ? `${ws.wind.toFixed(1)}<span class="value-unit">km/h</span>` : '--.-';
                    document.getElementById('ws-rain-today').innerHTML = ws.rain_today != null ? `${ws.rain_today.toFixed(1)}<span class="value-unit">mm</span>` : '--.-';
                    const rY = ws.rain_yesterday;
                    document.getElementById('ws-rain-yesterday').innerText = (rY != null) ? `${rY.toFixed(1)} mm` : '--.- mm';
                    document.getElementById('ws-meteo-status').innerText = ws.is_stormy ? t.storm : (ws.is_raining ? t.rain : t.clear);
                    document.getElementById('ws-sunshine').innerHTML = ws.sunshine_duration != null ? formatSunshine(ws.sunshine_duration) : '--h --m';
                    document.getElementById('ws-lux').innerText = ws.lux != null ? `${Math.round(ws.lux)} lx` : '-- lx';
                    document.getElementById('ws-flag-raining').innerText = ws.is_raining ? t.yes : t.no;
                    document.getElementById('ws-flag-storm').innerText = ws.is_stormy ? t.yes : t.no;
                }
                
                ['north', 'south', 'east', 'west'].forEach(dir => {
                    const temp = data[`house_${dir}`]?.temp;
                    if (temp != null) tempsForAvg.push(temp);
                    document.getElementById(`facade-${dir}`).innerText = (temp != null) ? temp.toFixed(1) + '°C' : '--.-°C';
                });
                if (data.greenhouse) {
                    const gT = data.greenhouse.temp;
                    document.getElementById('facade-greenhouse').innerHTML = (gT != null) ? `${gT.toFixed(1)}<span class="value-unit" style="color: var(--success);">°C</span>` : '--.-°C';
                    const watchdogEl = document.getElementById('ws-watchdog');
                    const isActive = data.greenhouse.watchdog_active;
                    watchdogEl.innerText = isActive ? t.on : t.off;
                    watchdogEl.style.color = isActive ? 'var(--text-dim)' : 'var(--accent)';
                    const energyEl = document.getElementById('ws-heater-energy');
                    const hEnergy = data.greenhouse.heater_energy;
                    energyEl.innerText = (hEnergy != null) ? `${hEnergy.toFixed(2)} kWh` : '--.- kWh';
                }
                
                if (data.irrigation) {
                    const irr = data.irrigation;
                    document.getElementById('ws-irrigation-today').innerHTML = irr.today != null ? `${Math.floor(irr.today * 60)}<span class="value-unit">m</span>` : '--<span class="value-unit">m</span>';
                    document.getElementById('ws-irrigation-yesterday').innerText = irr.yesterday != null ? `${Math.floor(irr.yesterday * 60)} m` : '-- m';
                    const stateEl = document.getElementById('ws-irrigation-state');
                    stateEl.innerText = irr.is_active ? t.on : t.off;
                    stateEl.style.color = irr.is_active ? 'var(--success)' : 'var(--text-dim)';
                }
                
                if (tempsForAvg.length > 0) {
                    const avg = tempsForAvg.reduce((a, b) => a + b, 0) / tempsForAvg.length;
                    document.getElementById('computed-avg').innerText = `${avg.toFixed(1)} °C`;
                }
            } catch (e) { 
                statusDot.className = "status-dot";
                statusText.innerText = `${t.error} (${lastUpdateStr || '--:--'})`;
            }
        }
        setInterval(() => {
            const d = new Date();
            document.getElementById('system-time').innerText = d.toLocaleTimeString('de-DE', { hour12: false }) + " // UTC" + (d.getTimezoneOffset() / -60 >= 0 ? "+" : "") + (d.getTimezoneOffset() / -60);
        }, 1000);
        fetchStatus();
        fetchLatestCameras();
        setInterval(() => {
            fetchStatus();
            fetchLatestCameras();
        }, 60000);
    </script>
    <script is:inline>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('SW registered!', reg))
                    .catch(err => console.error('SW registration failed', err));
            });
        }
    </script>
</body>
</html>

<style is:global>
    :root {
        --bg: #030303;
        --card-bg: rgba(14, 14, 14, 0.65);
        --card-border: rgba(214, 175, 55, 0.09);
        --card-border-hover: rgba(214, 175, 55, 0.25);
        --accent: #ca9f1b;
        --success: #10b981;
        --text-main: #f3f4f6;
        --text-muted: #4b5563;
        --text-dim: #9ca3af;
    }
    #weather-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -2;
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        transition: filter 3s ease;
    }
    .clickable { cursor: pointer; transition: background 0.2s, transform 0.2s; }
    .clickable:hover { background: rgba(255, 255, 255, 0.03); border-color: var(--card-border-hover); }
    .clickable:active { transform: scale(0.98); }
    body {
        font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
        background-color: var(--bg);
        background-image: 
            radial-gradient(circle at 0% 0%, rgba(214, 175, 55, 0.04), transparent 45%),
            radial-gradient(circle at 100% 100%, rgba(16, 185, 129, 0.02), transparent 45%),
            linear-gradient(to right, rgba(255, 255, 255, 0.01) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255, 255, 255, 0.01) 1px, transparent 1px);
        background-size: 100% 100%, 100% 100%, 64px 64px, 64px 64px;
        background-attachment: fixed;
        color: var(--text-main);
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 4rem 2rem;
        box-sizing: border-box;
    }
    .container { max-width: 1100px; width: 100%; }
    header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding-bottom: 2rem; }
