---
// Server-side block
---
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Burg | Wetterstation & Klima</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="container">
        <header>
            <div class="brand">
                <h1>Burg - Wetterdaten</h1>
                <p id="system-time">Live-Betriebszentrum</p>
            </div>
            <div class="status-badge">
                <div id="status-indicator" class="status-dot"></div>
                <span id="status-text">INITIALISIERE KONTEXT</span>
            </div>
        </header>

        <h2 class="section-title">📊 Kombisensor Wetterstation (HmIP-SWO-PL)</h2>
        <div class="bento-grid">
            
            <div class="card col-4">
                <div class="card-title">☀️ Außentemperatur</div>
                <div class="value-large" id="ws-temp">--.-<span class="value-unit">°C</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">System-Mittel</div>
                        <div class="sub-value" id="computed-avg" style="color: var(--accent);">--.- °C</div>
                    </div>
                    <div>
                        <div class="sub-label">Helligkeit</div>
                        <div class="sub-value" id="ws-lux">-- lx</div>
                    </div>
                </div>
            </div>

            <div class="card col-4">
                <div class="card-title">💨 Windgeschwindigkeit</div>
                <div class="value-large" id="ws-wind">--.-<span class="value-unit">km/h</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">Windrichtung</div>
                        <div class="sub-value" id="ws-wind-dir" style="color: var(--accent);">--</div>
                    </div>
                    <div>
                        <div class="sub-label">Luftfeuchte</div>
                        <div class="sub-value" id="ws-hum">-- %</div>
                    </div>
                </div>
            </div>

            <div class="card col-4">
                <div class="card-title">🌧️ Niederschlag (Heute)</div>
                <div class="value-large" id="ws-rain-today">--.-<span class="value-unit">mm</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">Regen Gestern</div>
                        <div class="sub-value" id="ws-rain-yesterday">--.- mm</div>
                    </div>
                    <div>
                        <div class="sub-label">Meteo-Status</div>
                        <div class="sub-value" id="ws-meteo-status">--</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bento-grid">
            <div class="card col-6">
                <div class="card-title">⏱️ Sonnenscheindauer (Heute)</div>
                <div class="value-large" id="ws-sunshine">--<span class="value-unit">h</span> --<span class="value-unit">m</span></div>
                <div class="sub-metrics">
                    <div>
                        <div class="sub-label">Sensor-Typ</div>
                        <div class="sub-value">Optisch</div>
                    </div>
                    <div>
                        <div class="sub-label">Schwelle</div>
                        <div class="sub-value">> 120 W/m²</div>
                    </div>
                </div>
            </div>

            <div class="card col-6">
                <div class="card-title">⚡ Sensor-Zustandsvektoren</div>
                <div class="facade-row">
                    <span class="facade-name">Akuter Niederschlag</span>
                    <span class="facade-val" id="ws-flag-raining">--</span>
                </div>
                <div class="facade-row">
                    <span class="facade-name">Sturmwahrnehmung</span>
                    <span class="facade-val" id="ws-flag-storm">--</span>
                </div>
            </div>
        </div>

        <h2 class="section-title">📈 Historische Niederschlagsstatistik (LTS)</h2>
        <div class="bento-grid">
            <div class="card col-12">
                <div class="card-title">📅 Monatliche Niederschlagsverteilung (2026)</div>
                <div class="history-chart-grid" id="history-chart-container">
                    </div>
            </div>
        </div>

        <h2 class="section-title">🧱 Struktur- & Biosphären-Klima</h2>
        <div class="bento-grid">
            <div class="card col-6">
                <div class="card-title">🏛️ Thermische Fassadenvektoren</div>
                <div class="facade-row">
                    <span class="facade-name">Nord-Fassade</span>
                    <span class="facade-val" id="facade-north">--.-°C</span>
                </div>
                <div class="facade-row">
                    <span class="facade-name">Süd-Fassade</span>
                    <span class="facade-val" id="facade-south">--.-°C</span>
                </div>
                <div class="facade-row">
                    <span class="facade-name">Ost-Fassade</span>
                    <span class="facade-val" id="facade-east">--.-°C</span>
                </div>
                <div class="facade-row">
                    <span class="facade-name">West-Fassade</span>
                    <span class="facade-val" id="facade-west">--.-°C</span>
                </div>
            </div>

            <div class="card col-6" style="background: radial-gradient(circle at 100% 0%, rgba(16, 185, 129, 0.04), transparent 60%), var(--card-bg);">
                <div class="card-title" style="color: var(--success);">🌿 Biosphären-Knoten (Gewächshaus)</div>
                <div class="value-large" id="facade-greenhouse">--.-<span class="value-unit" style="color: var(--success);">°C</span></div>
                <div class="sub-metrics" style="border-color: rgba(16, 185, 129, 0.1);">
                    <div>
                        <div class="sub-label">Atmosphären-Link</div>
                        <div class="sub-value" style="color: var(--success);">AKTIV</div>
                    </div>
                    <div>
                        <div class="sub-label">Heizungs-Watchdog</div>
                        <div class="sub-value" style="color: var(--text-dim);">AUTOMATISCH</div>
                    </div>
                </div>
            </div>
        </div>

        <footer>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;">ENG-CORE: V8-ISOLATE // FULL_METEO_DATA_STITCHING</div>
            <span id="uptime-display" style="margin:0;">SYSTEM_UPTIME: LOADING</span>
        </footer>
    </div>

    <script is:inline>
        const statusDot = document.getElementById('status-indicator');
        const statusText = document.getElementById('status-text');
        const uptimeDisplay = document.getElementById('uptime-display');
        const chartContainer = document.getElementById('history-chart-container');

        let isSimulationMode = false;

        document.querySelectorAll('.card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                card.style.setProperty('--x', `${e.clientX - rect.left}px`);
                card.style.setProperty('--y', `${e.clientY - rect.top}px`);
            });
        });

        function formatUptime(s) {
            const d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60);
            return `SYSTEM_UPTIME: ${d > 0 ? d + 'D ' : ''}${h > 0 ? h + 'H ' : ''}${m > 0 ? m + 'M ' : ''}${s % 60}S`;
        }

        function formatSunshine(minutesTotal) {
            const h = Math.floor(minutesTotal / 60);
            const m = minutesTotal % 60;
            return `${h}<span class="value-unit">h</span> ${m}<span class="value-unit">m</span>`;
        }

        function renderChart(monthlyData) {
            chartContainer.innerHTML = '';
            const months = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
            const maxVal = Math.max(...Object.values(monthlyData), 10);

            months.forEach(month => {
                const value = monthlyData[month] || 0;
                const percentage = (value / maxVal) * 100;

                const column = document.createElement('div');
                column.className = 'chart-column';
                column.innerHTML = `
                    <div class="chart-bar-container">
                        <div class="chart-bar" style="height: ${percentage}%"></div>
                    </div>
                    <div class="chart-value">${value.toFixed(1)}</div>
                    <div class="chart-label">${month.substring(0, 3)}</div>
                `;
                chartContainer.appendChild(column);
            });
        }

        function triggerSimulation() {
            if (!isSimulationMode) {
                isSimulationMode = true;
                statusDot.className = "status-dot online";
                statusText.innerText = "SIMULIERTE LABORUMGEBUNG";
                statusText.style.color = "var(--accent)";
                uptimeDisplay.innerText = formatUptime(174291);

                renderChart({
                    'Januar': 64.2, 'Februar': 48.1, 'März': 72.5, 'April': 38.0,
                    'Mai': 14.2, 'Juni': 0.0, 'Juli': 0.0, 'August': 0.0,
                    'September': 0.0, 'Oktober': 0.0, 'November': 0.0, 'Dezember': 0.0
                });
            }

            const baseTemp = 18.4 + Math.sin(Date.now()/50000)*2;
            const tNorth = baseTemp - 2.3;
            const tSouth = baseTemp + 4.1;
            const tEast = baseTemp + 1.2;
            const tWest = baseTemp - 0.5;
            const tGreenhouse = 24.6 + Math.sin(Date.now()/30000)*2;

            document.getElementById('ws-temp').innerHTML = `${baseTemp.toFixed(1)}<span class="value-unit">°C</span>`;
            document.getElementById('ws-hum').innerText = `${Math.round(62 + Math.cos(Date.now()/40000)*5)} %`;
            document.getElementById('ws-wind').innerHTML = `${(12.4 + Math.sin(Date.now()/10000)*4).toFixed(1)}<span class="value-unit">km/h</span>`;
            document.getElementById('ws-lux').innerText = `${Math.round(4500 + Math.sin(Date.now()/60000)*4000)} lx`;
            document.getElementById('ws-rain-today').innerHTML = `1.2<span class="value-unit">mm</span>`;
            document.getElementById('ws-rain-yesterday').innerText = `0.4 mm`;
            document.getElementById('ws-meteo-status').innerText = 'KLAR';
            
            // Simulating extended properties
            document.getElementById('ws-wind-dir').innerText = 'Nord-Ost (45°)';
            document.getElementById('ws-sunshine').innerHTML = formatSunshine(70); 
            document.getElementById('ws-flag-raining').innerText = 'NEIN';
            document.getElementById('ws-flag-storm').innerText = 'NEIN';

            document.getElementById('facade-north').innerText = `${tNorth.toFixed(1)}°C`;
            document.getElementById('facade-south').innerText = `${tSouth.toFixed(1)}°C`;
            document.getElementById('facade-east').innerText = `${tEast.toFixed(1)}°C`;
            document.getElementById('facade-west').innerText = `${tWest.toFixed(1)}°C`;
            document.getElementById('facade-greenhouse').innerHTML = `${tGreenhouse.toFixed(1)}<span class="value-unit" style="color: var(--success);">°C</span>`;

            const activeTemps = [baseTemp, tNorth, tSouth, tEast, tWest, tGreenhouse];
            const avg = activeTemps.reduce((a, b) => a + b, 0) / activeTemps.length;
            document.getElementById('computed-avg').innerText = `${avg.toFixed(1)} °C`;
        }

        async function fetchStatus() {
            try {
                const res = await fetch('/api/status');
                if (!res.ok) throw new Error("Proxy connection issue");
                
                const data = await res.json();
                if (data.error) throw new Error(data.error);
                
                isSimulationMode = false;
                statusDot.className = "status-dot online";
                statusText.innerText = "VERBINDUNG STABIL // HUB_ONLINE";
                statusText.style.color = "var(--success)";
                
                if (data.uptime !== undefined) uptimeDisplay.innerText = formatUptime(data.uptime);

                let rawWsTemp = null;

                if (data.weather_station) {
                    const ws = data.weather_station;
                    rawWsTemp = ws.temp;
                    document.getElementById('ws-temp').innerHTML = ws.temp !== null ? `${ws.temp.toFixed(1)}<span class="value-unit">°C</span>` : '--.-<span class="value-unit">°C</span>';
                    document.getElementById('ws-hum').innerText = ws.hum !== null ? `${Math.round(ws.hum)} %` : '-- %';
                    document.getElementById('ws-wind').innerHTML = ws.wind !== null ? `${ws.wind.toFixed(1)}<span class="value-unit">km/h</span>` : '--.-<span class="value-unit">km/h</span>';
                    document.getElementById('ws-lux').innerText = ws.lux !== null ? `${Math.round(ws.lux)} lx` : '-- lx';
                    document.getElementById('ws-rain-today').innerHTML = ws.rain_today !== null ? `${ws.rain_today.toFixed(1)}<span class="value-unit">mm</span>` : '--.-<span class="value-unit">mm</span>';
                    document.getElementById('ws-rain-yesterday').innerText = ws.rain_yesterday !== null ? `${ws.rain_yesterday.toFixed(1)} mm` : '--.- mm';
                    document.getElementById('ws-meteo-status').innerText = ws.is_stormy ? 'STURM' : (ws.is_raining ? 'REGEN' : 'KLAR');
                    
                    // Parsing additional SWO-PL entities dynamically mapping falling null buffers safely
                    document.getElementById('ws-wind-dir').innerText = ws.wind_direction !== undefined && ws.wind_direction !== null ? ws.wind_direction : 'N/A';
                    document.getElementById('ws-sunshine').innerHTML = ws.sunshine_duration !== undefined && ws.sunshine_duration !== null ? formatSunshine(ws.sunshine_duration) : '--<span class="value-unit">h</span> --<span class="value-unit">m</span>';
                    document.getElementById('ws-flag-raining').innerText = ws.is_raining ? 'JA' : 'NEIN';
                    document.getElementById('ws-flag-storm').innerText = ws.is_stormy ? 'JA' : 'NEIN';
                }

                const tNorth = data.house_north?.temp;
                const tSouth = data.house_south?.temp;
                const tEast = data.house_east?.temp;
                const tWest = data.house_west?.temp;
                const tGreenhouse = data.greenhouse?.temp;

                document.getElementById('facade-north').innerText = tNorth !== null && tNorth !== undefined ? `${tNorth.toFixed(1)}°C` : '--.-°C';
                document.getElementById('facade-south').innerText = tSouth !== null && tSouth !== undefined ? `${tSouth.toFixed(1)}°C` : '--.-°C';
                document.getElementById('facade-east').innerText = tEast !== null && tEast !== undefined ? `${tEast.toFixed(1)}°C` : '--.-°C';
                document.getElementById('facade-west').innerText = tWest !== null && tWest !== undefined ? `${tWest.toFixed(1)}°C` : '--.-°C';
                document.getElementById('facade-greenhouse').innerHTML = tGreenhouse !== null && tGreenhouse !== undefined ? `${tGreenhouse.toFixed(1)}<span class="value-unit" style="color: var(--success);">°C</span>` : '--.-<span class="value-unit" style="color: var(--success);">°C</span>';

                const dynamicArray = [rawWsTemp, tNorth, tSouth, tEast, tWest, tGreenhouse].filter(t => t !== null && t !== undefined);
                if (dynamicArray.length > 0) {
                    const calculatedAverage = dynamicArray.reduce((acc, val) => acc + val, 0) / dynamicArray.length;
                    document.getElementById('computed-avg').innerText = `${calculatedAverage.toFixed(1)} °C`;
                } else {
                    document.getElementById('computed-avg').innerText = '--.- °C';
                }

                if (data.historical_rain) {
                    renderChart(data.historical_rain);
                }

            } catch (e) { 
                triggerSimulation(); 
            }
        }

        setInterval(() => {
            const d = new Date();
            document.getElementById('system-time').innerText = d.toLocaleTimeString('de-DE', { hour12: false }) + " // UTC" + (d.getTimezoneOffset() / -60 >= 0 ? "+" : "") + (d.getTimezoneOffset() / -60);
        }, 1000);

        fetchStatus();
        setInterval(fetchStatus, isSimulationMode ? 2000 : 60000);
    </script>
</body>
</html>

<style is:global>
    :root {
        --bg: #030303;
        --card-bg: rgba(14, 14, 14, 0.65);
        --card-border: rgba(214, 175, 55, 0.09);
        --card-border-hover: rgba(214, 175, 55, 0.25);
        --accent: #ca9f1b;
        --success: #10b981;
        --text-main: #f3f4f6;
        --text-muted: #4b5563;
        --text-dim: #9ca3af;
    }

    body {
        font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
        background-color: var(--bg);
        /* We add the image to the end of the stack so gradients/grids sit on top of it */
        background-image: 
            radial-gradient(circle at 0% 0%, rgba(214, 175, 55, 0.04), transparent 45%),
            radial-gradient(circle at 100% 100%, rgba(16, 185, 129, 0.02), transparent 45%),
            linear-gradient(to right, rgba(255, 255, 255, 0.01) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255, 255, 255, 0.01) 1px, transparent 1px),
            url('/garten_bg.webp');
        
        /* 'cover' scales the image, 'center' centers it, 'fixed' keeps it crisp when scrolling */
        background-size: 100% 100%, 100% 100%, 64px 64px, 64px 64px, cover;
        background-position: center center;
        background-attachment: scroll, scroll, scroll, scroll, fixed;
        background-repeat: no-repeat;
        
        color: var(--text-main);
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 4rem 2rem;
        box-sizing: border-box;
    }

    .container { max-width: 1100px; width: 100%; }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        padding-bottom: 2rem;
        width: 100%;
    }

    .brand h1 {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        margin: 0;
        background: linear-gradient(135deg, #fff 50%, var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .brand p { margin: 0.35rem 0 0 0; font-size: 0.85rem; color: var(--text-dim); font-weight: 600; font-family: 'JetBrains Mono', monospace; }

    .status-badge {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 0.5rem 1.2rem;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
    }

    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: #374151; position: relative; }
    .status-dot.online { background: var(--success); box-shadow: 0 0 12px var(--success); }
    .status-dot.online::after {
        content: ''; position: absolute; width: 100%; height: 100%; top: 0; left: 0;
        border-radius: 50%; background: var(--success); animation: pulse 2s infinite;
    }
    @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(3); opacity: 0; } }

    .section-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin: 2rem 0 1rem 0;
        font-weight: 700;
        width: 100%;
    }

    .bento-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem; margin-bottom: 1.25rem; width: 100%; }
    .col-4 { grid-column: span 4; }
    .col-6 { grid-column: span 6; }
    .col-12 { grid-column: span 12; }

    .card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 1rem;
        padding: 1.75rem;
        backdrop-filter: blur(20px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
    }
    .card:hover { border-color: var(--card-border-hover); transform: translateY(-2px); box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.7); }

    .card-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: #52525b; font-weight: 700; margin-bottom: 1.25rem; }

    .value-large { font-family: 'JetBrains Mono', monospace; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; color: var(--text-main); line-height: 1.1; }
    .value-unit { font-size: 1.1rem; color: #4b5563; font-weight: 500; margin-left: 0.25rem; font-family: 'Plus Jakarta Sans', sans-serif; }

    .sub-metrics { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.04); padding-top: 1.25rem; }
    .sub-label { font-size: 0.68rem; color: #52525b; font-weight: 700; text-transform: uppercase; margin-bottom: 0.25rem; letter-spacing: 0.02em; }
    .sub-value { font-family: 'JetBrains Mono', monospace; font-size: 1.05rem; font-weight: 700; color: var(--text-dim); }

    .facade-row { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid rgba(255, 255, 255, 0.03); }
    .facade-row:last-child { border: none; padding-bottom: 0; }
    .facade-name { font-size: 0.85rem; font-weight: 600; color: var(--text-dim); }
    .facade-val { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.95rem; color: #fff; }

    .history-chart-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 0.75rem; min-height: 140px; align-items: flex-end; padding-top: 1rem; }
    .chart-column { display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
    .chart-bar-container { width: 100%; height: 100px; background: rgba(255,255,255,0.01); border-radius: 4px; display: flex; align-items: flex-end; overflow: hidden; border: 1px solid rgba(255,255,255,0.02); }
    .chart-bar { width: 100%; background: linear-gradient(to top, rgba(214, 175, 55, 0.2), var(--accent)); border-radius: 3px 3px 0 0; transition: height 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .chart-value { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--text-dim); font-weight: 700; margin: 0.4rem 0 0.15rem 0; }
    .chart-label { font-size: 0.7rem; text-transform: uppercase; color: #52525b; font-weight: 700; letter-spacing: 0.05em; }

    footer { margin-top: auto; padding-top: 4rem; display: flex; justify-content: space-between; align-items: center; color: #27272a; font-size: 0.75rem; font-weight: 600; border-top: 1px solid rgba(255, 255, 255, 0.03); width: 100%; }
</style>